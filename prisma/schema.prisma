generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Catalogue --------------------------------------------------------------

model Subject {
  id       String    @id @default(cuid())
  level    String
  slug     String
  name     String
  family   String
  products Product[]

  @@unique([level, slug])
}

model Product {
  id         String        @id @default(cuid())
  subject    Subject       @relation(fields: [subjectId], references: [id])
  subjectId  String
  key        String // forecast | companion | vault | rehearsal
  active     Boolean       @default(true)
  files      ProductFile[]
  orderItems OrderItem[]

  @@unique([subjectId, key])
}

// A product can ship more than one PDF — the Final Rehearsal is sold as a set
// of three (Paper 1, Paper 2, Mark Scheme) on a single product page. Each file
// gets its own download card, token, and per-download watermark.
model ProductFile {
  id         String      @id @default(cuid())
  product    Product     @relation(fields: [productId], references: [id])
  productId  String
  // Stable identifier within the product, e.g. "main", "paper1", "markscheme".
  key        String
  label      String
  // Path relative to PDF_STORAGE_DIR; never publicly routable.
  filePath   String
  sortOrder  Int         @default(0)
  // Set on admin re-upload, so owners see "updated — re-download" badges.
  updatedAt  DateTime?
  orderItems OrderItem[]

  @@unique([productId, key])
}

// Commerce ---------------------------------------------------------------

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  // Refer-a-friend: this customer's shareable code (minted on first visit to
  // the account section) and where to pay their cash rewards. The payout
  // handle is sensitive personal data (PDPA): admin-eyes only, never logged.
  referralCode String?    @unique
  payoutHandle String?
  // Opt-in weekly parent digest (PDPA: consent timestamp is the provable
  // opt-in; sentAt throttles the weekly cron). Parent email is theirs, not
  // the student's — admin-eyes only, never logged.
  parentEmail           String?
  parentDigestConsentAt DateTime?
  parentDigestSentAt    DateTime?
  // Last SG day (YYYY-MM-DD) a streak-reminder push went out — one per day
  // across all of the customer's devices.
  streakPingDay         String?
  orders                Order[]
  referrals             Referral[]
  pushSubscriptions     PushSubscription[]
  streakShields         StreakShield[]
}

// One FCM device token per native app install that enabled reminders
// (Android and iOS both route through Firebase Cloud Messaging). Dead tokens
// (UNREGISTERED from FCM) are deleted on send.
model NativePushToken {
  id         String   @id @default(cuid())
  customerId String
  token      String   @unique
  platform   String // ios | android
  createdAt  DateTime @default(now())

  @@index([customerId])
}

// One web-push subscription per browser/device the student enabled reminders
// on. endpoint is the push service URL (unique per subscription); p256dh/auth
// are the client's encryption keys. Dead endpoints (404/410 from the push
// service) are deleted on send.
model PushSubscription {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String
  endpoint   String   @unique
  p256dh     String
  auth       String
  createdAt  DateTime @default(now())

  @@index([customerId])
}

// One row per rewarded referral: `referrer` shared their code, the referee's
// order used it and was paid. Cash rewards are disbursed MANUALLY by the
// owner from the admin payouts list — nothing in the app moves money.
// status: payable (owed) -> paid (owner sent it) | void (referee refunded).
model Referral {
  id             String    @id @default(cuid())
  referrer       Customer  @relation(fields: [referrerId], references: [id])
  referrerId     String
  // Unique = one reward per order, and idempotent under webhook retries.
  refereeOrderId Int       @unique
  refereeEmail   String
  rewardCents    Int
  status         String    @default("payable")
  createdAt      DateTime  @default(now())
  paidAt         DateTime?

  @@index([referrerId])
}

model Order {
  id              Int         @id @default(autoincrement())
  // Unguessable token for the customer's download page URL.
  accessToken     String      @unique
  // Stripe Checkout session id; "mock_" prefix for test-mode orders created
  // without Stripe. Unique constraint is what makes order creation idempotent.
  stripeSessionId String      @unique
  status          String      @default("paid") // paid | refunded
  email           String
  customer        Customer    @relation(fields: [customerId], references: [id])
  customerId      String
  currency        String      @default("sgd")
  // All money in cents, matching Stripe.
  subtotalCents   Int
  discountCents   Int         @default(0)
  discountCode    String?
  totalCents      Int
  // Full PricedCart snapshot at purchase time, for audit and support.
  pricingJson     String
  createdAt       DateTime    @default(now())
  items           OrderItem[]
}

// One line per delivered FILE. A Master-tier subject with a three-part Final
// Rehearsal therefore has several order items sharing the same product.
model OrderItem {
  id            String         @id @default(cuid())
  order         Order          @relation(fields: [orderId], references: [id])
  orderId       Int
  product       Product        @relation(fields: [productId], references: [id])
  productId     String
  productFile   ProductFile    @relation(fields: [productFileId], references: [id])
  productFileId String
  // Denormalised for receipts even if the catalogue changes later.
  subjectName   String
  levelName     String
  productName   String
  fileLabel     String
  tier           String
  downloadToken  DownloadToken?
  downloadEvents DownloadEvent[]
}

model DownloadToken {
  token       String    @id
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  orderItemId String    @unique
  expiresAt   DateTime
  maxUses     Int
  uses        Int       @default(0)
}

// Study-plan progress: one row per topic a customer has touched. status:
// 0 untouched · 1 revised · 2 practised · 3 confident.
model TopicProgress {
  id         String   @id @default(cuid())
  customerId String
  level      String
  slug       String
  topic      String
  status     Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([customerId, level, slug, topic])
  @@index([customerId])
}

// Daily retrieval practice: one row per (customer, day). Streak = consecutive
// days with a row. `day` is a YYYY-MM-DD string in Asia/Singapore so the
// streak boundary matches the student's own midnight, not UTC. detailJson
// holds the per-question record ([{questionId, correct, confidence,
// resurrected}]) that powers the calibration card.
model DailyQuizDay {
  id         String   @id @default(cuid())
  customerId String
  day        String
  answered   Int      @default(0)
  correct    Int      @default(0)
  detailJson String?
  createdAt  DateTime @default(now())

  @@unique([customerId, day])
  @@index([customerId])
}

// The mistake notebook (错题本): every question a student got wrong, whether
// auto-seeded from a diagnostic/daily miss or added by hand from a school
// paper. reason: careless | concept | method | time. source: diagnostic |
// daily | manual. Resolved entries drop out of the review list.
//
// Resurrection (spaced re-testing): entries with a questionId come back in
// the daily three once nextResurfaceAt passes. Answer right twice in a row
// (clearStreak) and the entry auto-resolves; answer wrong and it returns in
// two days. Entries without a questionId (manual) are review-only.
model MistakeEntry {
  id              String    @id @default(cuid())
  customerId      String
  level           String
  slug            String
  topic           String
  questionId      String?
  stem            String
  correctAnswer   String?
  myAnswer        String?
  reason          String
  source          String
  note            String?
  resolved        Boolean   @default(false)
  resurfaceStage  Int       @default(0)
  clearStreak     Int       @default(0)
  nextResurfaceAt DateTime?
  createdAt       DateTime  @default(now())

  @@index([customerId])
}

// A student's target grade per subject ("A1", "B3", N(A) "Grade 2"). Drives
// the goal-gap card: latest estimate vs target, and which tier closes it.
model SubjectGoal {
  id          String   @id @default(cuid())
  customerId  String
  level       String
  slug        String
  targetGrade String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([customerId, level, slug])
  @@index([customerId])
}

// A customer's own exam timetable ("Physics P1", 19 Oct 2026 08:00) — entered
// manually until SEAB publishes the official 2026 dates.
model ExamDate {
  id         String   @id @default(cuid())
  customerId String
  label      String
  at         DateTime
  createdAt  DateTime @default(now())

  @@index([customerId])
}

// Money-back guarantee claims, filed from the dashboard. Handled by a human;
// the row is the audit trail. status: submitted | approved | rejected.
model GuaranteeClaim {
  id          String   @id @default(cuid())
  orderId     Int
  customerId  String
  subjectName String
  message     String
  status      String   @default("submitted")
  createdAt   DateTime @default(now())

  @@index([customerId])
}

// One row per successful download, for the customer's activity history. `via`
// records the path taken: "email" (a tokenised link) or "account" (signed-in).
model DownloadEvent {
  id          String    @id @default(cuid())
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  orderItemId String
  at          DateTime  @default(now())
  via         String

  @@index([orderItemId])
}

model DiscountCode {
  code           String    @id
  kind           String // percent | fixed (fixed value in cents)
  value          Int
  description    String    @default("")
  active         Boolean   @default(true)
  expiresAt      DateTime?
  maxRedemptions Int?
  redemptions    Int       @default(0)
  createdAt      DateTime  @default(now())
}

// Marketing --------------------------------------------------------------

model Lead {
  id          String   @id @default(cuid())
  email       String
  source      String
  level       String?
  subjectSlug String?
  // PDPA requires provable opt-in.
  consentAt   DateTime
  createdAt   DateTime @default(now())
}

// Carts where the shopper entered an email but didn't check out. A cron sends
// one recovery email after a delay, then leaves it alone. Cleared on purchase.
model AbandonedCart {
  id           String    @id @default(cuid())
  email        String    @unique
  itemsJson    String // JSON array of { level, subjectSlug, tier }
  discountCode String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  remindedAt   DateTime?
  recoveredAt  DateTime?
}

// Diagnostic ("Am I Ready?") ----------------------------------------------

// One quiz attempt. Graded server-side; the unguessable cuid doubles as the
// results-page access token (same pattern as Order.accessToken). Worked
// solutions are only served once `unlockedAt` is set by the email gate.
model DiagnosticAttempt {
  id                String    @id @default(cuid())
  level             String
  slug              String
  topic             String
  // [{questionId, given, correct, marksEarned, marks}] — grading audit trail.
  answersJson       String
  score             Int
  totalMarks        Int
  band              String // storm | cloudy | clear
  // Where the marks were dropped: companion | vault | null (nothing dropped).
  weakness          String?
  email             String?
  // Set when a signed-in customer takes the check, so the dashboard can show
  // their score history without an email round-trip. Anonymous takers stay null.
  customerId        String?
  leadId            String?
  isParent          Boolean   @default(false)
  utm               String?
  ref               String?
  unlockedAt        DateTime?
  resultEmailSentAt DateTime?
  followUpAt        DateTime?
  followUpSentAt    DateTime?
  createdAt         DateTime  @default(now())

  @@index([followUpAt])
}

// Funnel telemetry, surfaced on the admin dashboard next to orders/leads.
model DiagnosticEvent {
  id        String   @id @default(cuid())
  attemptId String?
  type      String
  meta      String?
  createdAt DateTime @default(now())

  @@index([type])
}

// Visitor journey analytics (first-party, anonymous, no PII). One row per
// visit (session); pageview/click events hang off it. Keyed by random client
// ids; referrer is stored as bare hostname only.
model VisitorSession {
  id          String         @id
  visitorId   String
  startedAt   DateTime       @default(now())
  lastSeenAt  DateTime       @default(now())
  landingPath String
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  device      String
  isReturning Boolean        @default(false)
  pageviews   Int            @default(0)
  clicks      Int            @default(0)
  events      VisitorEvent[]

  @@index([startedAt])
  @@index([visitorId])
}

model VisitorEvent {
  id        String         @id @default(cuid())
  session   VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  type      String // "pageview" | "click"
  path      String
  label     String?
  createdAt DateTime       @default(now())

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
}

// Game layer ("Clear the Fog") ---------------------------------------------

// One row per XP award. Server-authoritative: XP is only ever granted inside
// API routes when a real study action happens, and `sourceKey` is unique per
// customer so no action can be farmed (re-doing it hits the unique index and
// awards nothing). Level/title are derived from SUM(amount) at read time.
model XpEvent {
  id         String   @id @default(cuid())
  customerId String
  amount     Int
  kind       String // daily | mistake_cleared | topic_up | diagnostic | focus | badge
  sourceKey  String
  meta       String?
  createdAt  DateTime @default(now())

  @@unique([customerId, sourceKey])
  @@index([customerId])
}

// Unlocked badges. Definitions (names, emoji, hints) live in code
// (src/lib/game.ts); this table only records who unlocked what, when.
model Achievement {
  id         String   @id @default(cuid())
  customerId String
  badgeId    String
  unlockedAt DateTime @default(now())

  @@unique([customerId, badgeId])
  @@index([customerId])
}

// Operations -------------------------------------------------------------

model Setting {
  key   String @id
  value String
}

// Streak insurance, earned by effort (every 5th consecutive daily-three day,
// max 2 held). Spent automatically — and at most one per missed day — when
// yesterday was missed but the day before wasn't, so a single slip doesn't
// erase weeks of habit. Compliance: earned only, never bought.
model StreakShield {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  earnedDay  String
  spentDay   String?
  createdAt  DateTime @default(now())

  @@unique([customerId, earnedDay])
  @@unique([customerId, spentDay])
}

// Study Duels: asynchronous student-vs-student challenges. A creator seals
// a server-dealt question set behind a share code; one challenger answers
// the SAME set; scores compare privately. No leaderboards, no chat, no
// stranger discovery — codes travel outside the app between friends.
model Duel {
  id             String   @id @default(cuid())
  code           String   @unique
  level          String
  slug           String
  questionIdsJson String
  creatorId      String
  creatorScore   Int?
  challengerId   String?
  challengerScore Int?
  createdAt      DateTime @default(now())

  @@index([creatorId])
  @@index([challengerId])
}

// Game content bank. Authored in content/game-bank/*.md, seeded here by
// seedGameBank() (idempotent). The runtime reads from these tables via the
// server-only question-bank layer, so answer keys (correctJson,
// workedSolution) live only in the database and never enter any JS bundle.
model GameQuestion {
  id              String  @id // stable "<slug>-g<n>" from the source file
  level           String
  slug            String
  ord             Int     @default(0)
  type            String  // "mcq" | "short"
  topic           String
  stem            String
  optionsJson     String? // JSON array of option strings (mcq only)
  correctJson     String  // JSON array: mcq = [optionIndex]; short = accepted[]
  marks           Int     @default(1)
  workedSolution  String
  misconceptionTag String @default("unset")
  // 1 = easy, 2 = medium, 3 = hard. Drives diagnostic hard-question selection
  // and lets StudyLah Legends ramp battle difficulty. Authored in the markdown
  // bank (`difficulty:`); inferred from the question's signals when omitted.
  difficulty      Int     @default(2)

  @@index([level, slug])
}

model GameTeachingCard {
  id       String @id @default(cuid())
  level    String
  slug     String
  ord      Int    @default(0)
  kind     String // definition | precision | qa | careless | sbq | poa
  dataJson String // the card's remaining fields, verbatim from source

  @@index([level, slug])
}

// Unified spaced-repetition state (Leitner boxes 1..5, intervals 1/3/7/21/60
// days). kind: "question" (daily-quiz correct answers; wrong ones ride the
// mistake notebook), "definition" (GameTeachingCard definition/precision ids),
// "formula" (formula-bank ids).
model ReviewCard {
  id         String   @id @default(cuid())
  customerId String
  kind       String
  itemKey    String
  level      String
  slug       String
  box        Int      @default(1)
  reps       Int      @default(0)
  lapses     Int      @default(0)
  dueAt      DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@unique([customerId, kind, itemKey])
  @@index([customerId, kind, dueAt])
}

// Beta feedback for StudyLah Legends: free text + a quick sentiment tap.
model GameFeedback {
  id         String   @id @default(cuid())
  customerId String
  sentiment  String? // "love" | "okay" | "rough"
  message    String
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// One turn of a Messenger or Instagram DM conversation with Gugu (Meta
// Graph webhook). Mirrors WaMessage but carries a channel discriminator since
// both platforms share the same webhook + Page token. contactId is the
// platform-scoped sender id (PSID for Messenger, IGSID for Instagram).
model SocialMessage {
  id        String   @id @default(cuid())
  channel   String // "messenger" | "instagram"
  contactId String
  role      String // "user" | "assistant"
  content   String
  msgId     String?  @unique
  manual    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([channel, contactId, createdAt])
}

// One turn of a WhatsApp conversation with Gugu (via the Meta Cloud API
// webhook). waId is the visitor's WhatsApp number; msgId is Meta's message id,
// unique so redelivered webhooks can't double-process the same message.
model WaMessage {
  id        String   @id @default(cuid())
  waId      String
  role      String // "user" | "assistant"
  content   String
  msgId     String?  @unique
  // true = sent by the owner from the admin inbox (human takeover). Gugu
  // stays silent on a thread for 24h after the last manual reply.
  manual    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([waId, createdAt])
}
