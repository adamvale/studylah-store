# StudyLah environment variables
# Copy to .env for LOCAL dev and fill in. The app runs fully in dev with these
# left as-is:
#   - Stripe unset  -> checkout runs in MOCK MODE (orders created without
#                      payment, clearly labelled in the UI) so delivery is
#                      testable locally.
#   - Resend unset  -> emails are written to data/outbox/ instead of sent.
#
# For PRODUCTION (Railway/Render/etc.) you set these in the host's dashboard,
# NOT in a committed file. Production values are called out below and the full
# walkthrough is in DEPLOY.md.

# --- Database ---
# Local: a SQLite file in the project. Production: point at the mounted
# persistent volume, e.g. DATABASE_URL="file:/data/prod.db" (the Dockerfile
# sets this for you).
DATABASE_URL="file:./prisma/dev.db"

# Where product PDFs live. Never publicly routable; served only through signed
# download tokens. Production: put this on the volume too, e.g.
# PDF_STORAGE_DIR="/data/pdfs" (the Dockerfile sets this for you).
PDF_STORAGE_DIR="private/pdfs"

# --- Stripe — TEST MODE keys, never live keys in this file ---
# Leave as REPLACE_ME to run checkout in mock mode. Set a real sk_test_ key
# to use Stripe Checkout (PayNow + cards, with an automatic card-only
# fallback if PayNow isn't enabled on the account).
STRIPE_SECRET_KEY="sk_test_REPLACE_ME"
STRIPE_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
# From `stripe listen --forward-to localhost:3000/api/webhooks/stripe` in dev,
# or the dashboard webhook config in prod.
STRIPE_WEBHOOK_SECRET="whsec_REPLACE_ME"

# --- Email ---
# Leave empty to write emails to data/outbox/ (dev stub). Set a Resend API
# key to send for real.
RESEND_API_KEY=""
EMAIL_FROM="StudyLah <orders@studylah.education>"

# --- Downloads ---
# Download links expire after this many days / uses, whichever comes first.
# Tokens are unguessable random values stored in the database (not signed),
# so no signing secret is needed.
DOWNLOAD_EXPIRY_DAYS="7"
DOWNLOAD_MAX_USES="5"

# --- Admin ---
# Protects /admin. Local can be "change-me"; in PRODUCTION set a long, random
# value (e.g. `openssl rand -base64 24`). Changing it logs everyone out.
ADMIN_PASSWORD="change-me"

# --- Scheduled jobs ---
# Protects /api/cron/* (the diagnostic 48h follow-up email). Set a random
# value (`openssl rand -hex 24`) and point a scheduler (Railway cron or
# cron-job.org, hourly) at:
#   https://www.studylah.education/api/cron/diagnostic-followup?key=<value>
# Blank = the endpoint stays disabled (fail closed).
CRON_SECRET=""

# --- Customer accounts (magic-link login at /account) ---
# Signs customer sign-in links and session cookies. In PRODUCTION this MUST be
# set to a long random value (e.g. `openssl rand -hex 32`); if left blank in
# production, customer login is disabled (fail closed). Independent of
# ADMIN_PASSWORD. Changing it signs every customer out.
CUSTOMER_AUTH_SECRET=""

# --- Site ---
# Local: localhost. Production: your public URL, e.g.
# NEXT_PUBLIC_SITE_URL="https://shop.studylah.education" — used in emails and
# the Stripe success/cancel redirects, so it must match the real domain.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Web push (PWA streak reminders): generate with `npx web-push generate-vapid-keys`.
# The public key is safe to expose; the private key must stay secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:hello@studylah.education"

# Cloudflare R2 (offsite DB backups + master content store). S3-compatible
# credentials from the R2 dashboard; blank = backups disabled (fail closed).
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT=""
R2_BUCKET=""

# Native app push — Android via FCM: base64 of the Firebase service-account
# JSON (Firebase console → Project settings → Service accounts). Blank = off.
FIREBASE_SERVICE_ACCOUNT_B64=""

# Native app push — iOS via APNs: p8 token auth (Apple Developer → Keys).
# All four required; blank = off. APNS_SANDBOX=1 only for dev builds.
APNS_KEY_B64=""
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_BUNDLE_ID="education.studylah.app"
APNS_SANDBOX=""

# App-review demo login: this exact email+code pair always signs in (for
# Apple/Google reviewers who cannot receive our emails). Point at a demo
# customer with sample orders — NEVER a real one. Blank = disabled.
REVIEW_EMAIL=""
REVIEW_CODE=""

# --- WhatsApp Gugu (Meta Cloud API) — full setup in docs/WHATSAPP-SETUP.md ---
# ALL FOUR blank = local stub mode: the webhook still works and Gugu's replies
# are written to data/outbox/ instead of sent, so the flow is testable without
# a Meta account. In production set all four.
# Verify token: any random string YOU invent (`openssl rand -hex 16`); paste
# the same value in the Meta webhook config.
WHATSAPP_VERIFY_TOKEN=""
# From Meta: WhatsApp → API Setup (permanent token via a System User).
WHATSAPP_ACCESS_TOKEN=""
# The bot number's "Phone number ID" (NOT the phone number itself).
WHATSAPP_PHONE_NUMBER_ID=""
# Meta App → Settings → Basic → App secret. Signs every webhook delivery;
# required in production for the signature check.
WHATSAPP_APP_SECRET=""

# --- Messenger + Instagram Gugu (same Meta app as WhatsApp) ---
# Both channels share the same webhook (/api/webhooks/messenger), the same app
# secret, and one Page access token. Blank = stub mode (replies to data/outbox).
# The Page access token for the Facebook Page connected to the app (Messenger)
# and its linked Instagram Professional account (Instagram DMs). Generate a
# permanent one via a System User assigned to the Page.
META_PAGE_ACCESS_TOKEN=""
# Optional: defaults to WHATSAPP_APP_SECRET / WHATSAPP_VERIFY_TOKEN (same app),
# so you normally leave these blank. Set only if you use a different app.
META_APP_SECRET=""
MESSENGER_VERIFY_TOKEN=""
